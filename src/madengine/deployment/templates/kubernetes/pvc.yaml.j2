apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ pvc_name }}
  namespace: {{ namespace }}
  labels:
    app: madengine
    madengine-pvc: "true"
spec:
  accessModes:
    # RWO: single-node results (e.g. local-path). RWX: multi-node (e.g. nfs-banff).
    - {{ access_mode | default("ReadWriteOnce") }}
  resources:
    requests:
      storage: {{ storage_size | default("10Gi") }}
  {% if storage_class %}
  storageClassName: {{ storage_class }}
  {% endif %}

