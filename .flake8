[flake8]
max-line-length = 88
extend-ignore =
    E203,
    E266,
    E402,
    E501,
    E741,
    F541,
    F811,
    F824,
    W503,
    W291,
    W293,
    W391
per-file-ignores =
    tests/*:F401,F811,F405,F403,F841,E402,E712,E713
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .eggs,
    *.egg-info,
    venv,
    .venv,
    src/madengine/scripts/,
    tests/fixtures/dummy/scripts/
